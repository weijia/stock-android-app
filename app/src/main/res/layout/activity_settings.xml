<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/background">

    <!-- 标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_title"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/textPrimary" />

    <!-- 数据源选择 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/label_data_source"
        android:textColor="@color/textSecondary"
        android:textSize="14sp" />

    <RadioGroup
        android:id="@+id/rg_data_source"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/rb_local"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/data_source_local"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rb_itick"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/data_source_itick" />
    </RadioGroup>

    <!-- 本地服务器配置区域 -->
    <LinearLayout
        android:id="@+id/local_server_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 服务器地址 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_server_ip"
            android:textColor="@color/textSecondary"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/et_server_ip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/hint_server_ip"
            android:inputType="text"
            android:maxLines="1"
            android:background="@color/surface"
            android:padding="12dp" />

        <!-- 端口 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_server_port"
            android:textColor="@color/textSecondary"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/et_server_port"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/hint_server_port"
            android:inputType="number"
            android:maxLines="1"
            android:background="@color/surface"
            android:padding="12dp" />

        <!-- 测试连接按钮 -->
        <Button
            android:id="@+id/btn_test_connection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/btn_test_connection"
            android:background="@color/textSecondary"
            android:textColor="@color/surface" />

        <!-- 测试结果 -->
        <TextView
            android:id="@+id/tv_test_result"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="14sp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- iTick 配置区域 -->
    <LinearLayout
        android:id="@+id/itick_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- iTick Token -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_itick_token"
            android:textColor="@color/textSecondary"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/et_itick_token"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/hint_itick_token"
            android:inputType="text"
            android:maxLines="1"
            android:background="@color/surface"
            android:padding="12dp" />

        <!-- 市场区域 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_itick_region"
            android:textColor="@color/textSecondary"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/sp_itick_region"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@color/surface"
            android:padding="12dp" />

        <!-- 测试 iTick Token 按钮 -->
        <Button
            android:id="@+id/btn_test_itick"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="测试 iTick Token"
            android:background="@color/textSecondary"
            android:textColor="@color/surface" />

        <!-- iTick 测试结果 -->
        <TextView
            android:id="@+id/tv_itick_test_result"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="14sp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="24dp"
        android:background="@color/chartGrid" />

    <!-- 外部存储配置区域 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="外部存储配置"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/textPrimary" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="配置保存到外部存储，卸载应用后保留"
        android:textColor="@color/textSecondary"
        android:textSize="12sp" />

    <!-- 存储位置显示 -->
    <TextView
        android:id="@+id/tv_storage_location"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="配置保存位置: SharedPreferences"
        android:textColor="@color/textSecondary"
        android:textSize="12sp" />

    <!-- 选择外部存储目录按钮 -->
    <Button
        android:id="@+id/btn_select_storage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="选择外部存储目录"
        android:background="@color/colorAccent"
        android:textColor="@color/surface" />

    <!-- 保存按钮 -->
    <Button
        android:id="@+id/btn_save"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/btn_save"
        android:background="@color/colorPrimary"
        android:textColor="@color/surface" />

</LinearLayout>